<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             Foreground="{DynamicResource PrimaryForeground}"
             Background="{DynamicResource PrimaryBackground}"
             xmlns:vm="clr-namespace:Chess_D_B.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:DataType="vm:DashboardPageViewModel"
             x:Class="Chess_D_B.Views.DashboardPageView">

    <Grid RowDefinitions="Auto, Auto, *">

        <Border Grid.Row="0" Background="#34495E" Padding="20">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="ChartBar" Width="28" Height="28" Foreground="White"/>
                <TextBlock Text="Tableau de Bord de la Fédération"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="10" Background="#2C3E50">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="10,0">
                    <mi:MaterialIcon Kind="{Binding MessageIcon}" Width="16" Height="16" Foreground="White"/>
                    <TextBlock Text="{Binding Message}"
                               FontSize="14"
                               Foreground="White"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding ChargerDonneesCommand}"
                        Height="35"
                        Background="#2980b9"
                        IsEnabled="{Binding !EstEnChargement}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                        <TextBlock Text="Rafraîchir"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="20">
            <StackPanel Spacing="20">

                <TextBlock Text="Statistiques Globales" FontSize="20" FontWeight="Bold" Foreground="#3498db" Margin="0,10,0,0"/>

                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">

                    <Border Grid.Column="0" Background="#3498db" CornerRadius="10" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="AccountGroup" Width="16" Height="16" Foreground="White"/>
                                <TextBlock Text="Joueurs Enregistrés" FontSize="16" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalJoueurs}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1abc9c" CornerRadius="10" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Trophy" Width="16" Height="16" Foreground="White"/>
                                <TextBlock Text="Compétitions" FontSize="16" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalCompetitions}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#f39c12" CornerRadius="10" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="ChessPawn" Width="16" Height="16" Foreground="White"/>
                                <TextBlock Text="Matchs Joués" FontSize="16" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalMatchs}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Top 5 des Joueurs (ELO)" FontSize="20" FontWeight="Bold" Foreground="#3498db" Margin="0,20,0,0"/>

                <ListBox ItemsSource="{Binding TopJoueurs}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15" Margin="0,0,0,5" Background="#2C3E50" CornerRadius="5">
                                <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="20">



                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Nom}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Elo, StringFormat='ELO: {0}'}"
                                               FontSize="16"
                                               Foreground="#27ae60"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
