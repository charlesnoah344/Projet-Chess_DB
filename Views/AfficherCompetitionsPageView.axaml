<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             Foreground="{DynamicResource PrimaryForeground}"
             Background="{DynamicResource PrimaryBackground}"
             xmlns:vm="clr-namespace:Chess_D_B.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:DataType="vm:AfficherCompetitionsPageViewModel"
             x:Class="Chess_D_B.Views.AfficherCompetitionsPageView">

    <Grid RowDefinitions="Auto, Auto, *, Auto">

        <Border Grid.Row="0" Background="#16a085" Padding="20">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="Trophy" Width="28" Height="28" Foreground="White"/>
                <TextBlock Text="Liste des Compétitions"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="15" Background="#1abc9c">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="{Binding MessageIcon}" Width="16" Height="16" Foreground="White"/>
                <TextBlock Text="{Binding Message}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="20">
            <ListBox ItemsSource="{Binding Competitions}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#34495E"
                                Padding="20"
                                Margin="0,0,0,10"
                                CornerRadius="5"
                                Cursor="Hand">
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="Background" Value="#2C3E50"/>
                                </Style>
                            </Border.Styles>

                            <Grid RowDefinitions="Auto, Auto, Auto">
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Tournoi}"
                                           FontSize="20"
                                           FontWeight="Bold"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="15" Margin="0,5,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <mi:MaterialIcon Kind="MapMarker" Width="14" Height="14" Foreground="#95a5a6"/>
                                        <TextBlock Text="{Binding Ville}"
                                                   FontSize="14"
                                                   Foreground="#95a5a6"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <mi:MaterialIcon Kind="Calendar" Width="14" Height="14" Foreground="#95a5a6"/>
                                        <TextBlock Text="{Binding DateDebut, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                   FontSize="14"
                                                   Foreground="#95a5a6"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Row="2"
                                        Command="{Binding $parent[UserControl].DataContext.OuvrirCompetitionCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,10,0,0"
                                        Height="35"
                                        HorizontalAlignment="Stretch"
                                        Background="#16a085">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <mi:MaterialIcon Kind="Eye" Width="16" Height="16"/>
                                        <TextBlock Text="Ouvrir la compétition"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Margin="20" Spacing="10">
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding EstEnChargement}"
                         Height="4"/>

            <Button Command="{Binding RetourCommand}"
                    HorizontalAlignment="Left"
                    Width="200"
                    Height="40">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <mi:MaterialIcon Kind="ArrowLeft" Width="16" Height="16"/>
                    <TextBlock Text="Retour"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
